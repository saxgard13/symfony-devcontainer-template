ARG PHP_VERSION=8.3
ARG NODE_VERSION=22

FROM php:${PHP_VERSION}-cli

# Re-declare ARG after FROM (they don't persist across stages)
ARG NODE_VERSION

# Install system dependencies, Node.js, Symfony CLI in a single layer
RUN set -o pipefail && apt-get update \
    && apt-get install -y --no-install-recommends \
        curl \
        git \
        jq \
        lsof \
        nano \
        openssh-client \
        procps \
        tree \
        unzip \
        wget \
        zip \
        sudo \
    # Install Node.js with retries
    && for _ in 1 2 3; do curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - && break || sleep 5; done \
    && apt-get install -y --no-install-recommends nodejs \
    # Install Symfony CLI with retries
    && for _ in 1 2 3; do curl -sS https://get.symfony.com/cli/installer | bash && break || sleep 5; done \
    && mv /root/.symfony5/bin/symfony /usr/local/bin/symfony \
    && rm -rf /root/.symfony5 \
    # clean up
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Install Playwright CLI and Context7 CLI globally
# hadolint ignore=DL3016
RUN npm install -g @playwright/cli@latest \
    && npm install -g ctx7

# Install Playwright browser dependencies
RUN npx playwright install-deps chromium

# Install PHP extensions (separate layer for better caching)
COPY --from=mlocati/php-extension-installer /usr/bin/install-php-extensions /usr/local/bin/
RUN install-php-extensions \
    bcmath \
    gd \
    intl \
    opcache \
    pdo_mysql \
    redis \
    xdebug \
    zip

# Enable pnpm and yarn via corepack (npm remains available by default)
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy config files and binaries (COPY uses minimal layers)
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer
COPY .devcontainer/config/php.ini /usr/local/etc/php/php.ini

# Create non-root user
RUN groupadd -g 1000 vscode \
    && useradd -u 1000 -g vscode -m vscode \
    && echo "vscode ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/vscode \
    && chmod 0440 /etc/sudoers.d/vscode

USER vscode
WORKDIR /workspace
