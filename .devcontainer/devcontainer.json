{
  "name": "App Symfony",
  "dockerComposeFile": [
    "docker-compose.dev.yml",
    "docker-compose.mysql.yml",
    "docker-compose.redis.yml",
    "docker-compose.mailpit.yml"
  ],
  "service": "dev",
  "workspaceFolder": "/workspace-devcontainer",
  "customizations": {
    "vscode": {
      "extensions": [
        "xdebug.php-debug",
        "bmewburn.vscode-intelephense-client",
        "cweijan.vscode-mysql-client2",
        "neilbrayfield.php-docblocker",
        "dsznajder.es7-react-js-snippets",
        "MehediDracula.php-namespace-resolver",
        "mblode.twig-language-2",
        "joffreykern.markdown-toc",
        "mikestead.dotenv",
        "junstyle.php-cs-fixer",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "database-client.autoSync": true,
        "php.suggest.basic": false,
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "intelephense.environment.phpVersion": "8.3",
        "intelephense.files.maxSize": 5000000,
        "php.validate.enable": true,
        "php.validate.executablePath": "/usr/local/bin/php",
        "files.exclude": {
          "**/.git": true,
          "**/.idea": true,
          "**/vendor": false
        },
        "files.watcherExclude": {
          "**/node_modules/**": true,
          "**/.git/objects/**": true,
          "**/dist/**": true,
          "**/vendor/**": true,
          "**/var/cache/**": true,
          "**/var/log/**": true
        },
        "php-cs-fixer.executablePath": "${workspaceFolder}/project/backend/vendor/bin/php-cs-fixer",
        "php-cs-fixer.onsave": true,
        "php-cs-fixer.config": "${workspaceFolder}/project/backend/.php-cs-fixer.php;${workspaceFolder}/project/backend/.php-cs-fixer.dist.php;${workspaceFolder}/project/backend/.php_cs;${workspaceFolder}/project/backend/.php_cs.dist",
        "php-cs-fixer.allowRisky": false,
        "php-cs-fixer.pathMode": "override",
        "php-cs-fixer.ignorePHPVersion": false,
        "php-cs-fixer.exclude": ["vendor", "node_modules", "var", "storage"],
        "php-cs-fixer.autoFixByBracket": false,
        "php-cs-fixer.autoFixBySemicolon": false,
        "php-cs-fixer.formatHtml": false,
        "php-cs-fixer.documentFormattingProvider": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[php]": {
          "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
        }
      }
    }
  },
  "overrideCommand": false,
  "remoteUser": "vscode",
  "shutdownAction": "stopCompose",
  "containerEnv": {
    "GIT_USER_NAME": "${localEnv:GIT_USER_NAME}",
    "GIT_USER_EMAIL": "${localEnv:GIT_USER_EMAIL}"
  },
  "initializeCommand": "bash .devcontainer/init.sh",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.symfony5,target=/home/vscode/.config/symfony-cli,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached"
  ],
  "forwardPorts": [8000, 8443, 9003, 5173, 5443, 3000, 3443],
  "portsAttributes": {
    "8000": { "label": "Symfony Server (HTTP)" },
    "8443": { "label": "Symfony HTTPS (Caddy)", "protocol": "https" },
    "9003": { "label": "Xdebug" },
    "5173": { "label": "Vite (HTTP)" },
    "5443": { "label": "Vite HTTPS (Caddy)", "protocol": "https" },
    "8025": { "label": "Mailpit" },
    "3000": { "label": "Next, Nuxt etc. (HTTP)" },
    "3443": { "label": "Next, Nuxt HTTPS (Caddy)", "protocol": "https" }
  }
}
