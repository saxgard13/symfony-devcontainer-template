# ==============================================================================
# MANAGED BY .config.json — do not edit here, run: bash scripts/update-config.sh
# ==============================================================================
PROJECT_NAME=devcontainer
PHP_VERSION=8.3
NODE_VERSION=22
DEV_IMAGE=symfony-devcontainer-template-image:php8.3-node22
FRONTEND_LOCALHOST_PORT=5173
DB_IMAGE=mysql:8.3
SERVER_VERSION=8.3 # Required for MySQL/MariaDB (e.g. 8.3 or mariadb-10.11). Leave empty for PostgreSQL.
REDIS_IMAGE=redis:7-alpine
ADMINER_IMAGE=adminer:latest

# ==============================================================================
# OVERRIDE IN .env.local — do not commit sensitive values
# ==============================================================================
MYSQL_ROOT_PASSWORD=roots
MYSQL_USER=symfony
MYSQL_PASSWORD=symfony

GIT_USER_NAME=DefaultName
GIT_USER_EMAIL=default@example.com

# Set to true to clear VS Code extensions cache on container startup
CLEAN_VSCODE_EXTENSIONS=false
